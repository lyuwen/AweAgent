# AweAgent environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Backend (pick one) ─────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # default

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o              # default
# AZURE_API_VERSION=2024-06-01                 # default

# Volcengine Ark
# ARK_API_KEY=
# ARK_MODEL_ID=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3  # default

# SGLang (self-hosted)
# SGLANG_ROUTER_IP=localhost                   # default
# SGLANG_ROUTER_PORT=30000                     # default

# ── Task Data ──────────────────────────────────────────────────────

DATA_FILE=/path/to/data.jsonl

# BeyondSWE doc2repo: directory containing test suite ZIP files
# BEYONDSWE_TEST_SUITE_DIR=/path/to/test_suites

# ── Search Tools (BeyondSWE search mode only) ─────────────────────

# SERPAPI_API_KEY=                              # SerpAPI search backend
# JINA_API_KEY=                                 # Jina reader (optional, 20 RPM without key)

# Link summary LLM (used by search mode to summarize fetched pages)
# LINK_SUMMARY_CONFIG_PATH=configs/llm/link_summary/azure.yaml
# LINK_SUMMARY_MODEL=gpt-4o-mini               # overrides model in config
# LINK_SUMMARY_AZURE_ENDPOINT=https://your-resource.openai.azure.com
# LINK_SUMMARY_API_KEY=
# LINK_SUMMARY_API_VERSION=2024-03-01-preview   # default
